{
  "expo": {
    "name": "lawyers-mobile-app",
    "slug": "lawyers-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "lawyersmobileapp",
    "userInterfaceStyle": "automatic",
    "notification": {
      "color": "#1565C0",
      "iosDisplayInForeground": true
    },
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.egyptianlawyers.app",
      "UIBackgroundModes": [
        "remote-notification"
      ]
    },
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.egyptianlawyers.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#1565C0",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "45c60c89-a8cb-4f5f-be32-c5bd97774eea"
      }
    }
  }
}